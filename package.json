{
  "name": "atmos-monorepo",
  "version": "1.0.0",
  "description": "Sovereign P2P compute layer and StratosAgent browser automation framework",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "node scripts/ci-test.mjs",
    "test:deepscan": "node packages/stratos-agent/test-deepscan-telegram.js",
    "test:deepscan:fips": "node --enable-fips packages/stratos-agent/test-deepscan-telegram.js",
    "test:all": "npm run test --workspaces --if-present",
    "start:shim": "node packages/api-shim/index.js",
    "start:shim:fips": "node --enable-fips packages/api-shim/index.js",
    "start:maximus": "npm run start --workspace=packages/maximus-telemetry",
    "start:desktop": "npm run tauri dev --workspace=packages/atmos-desktop",
    "test:ci": "node scripts/ci-test.mjs",
    "audit:prod": "node scripts/audit-prod-gate.mjs"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.29.0",
    "@slack/bolt": "^4.7.3",
    "@solana/web3.js": "^1.98.4",
    "discord.js": "^14.26.4",
    "matrix-js-sdk": "^41.6.0"
  },
  "overrides": {
    "form-data": "^4.0.6",
    "undici": "^6.27.0",
    "jayson": {
      "uuid": "^14.0.1"
    }
  }
}
